{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "watchPatterns": [
            "src/dashboard/**"
        ]
    },
    "deploy": {
        "startCommand": "cd src/dashboard && npm start",
        "healthcheckPath": "/",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE"
    }
}