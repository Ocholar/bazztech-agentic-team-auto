generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// -------------------------------------------------------------
// USER & AUTHENTICATION (Multi-Tenant SaaS)
// -------------------------------------------------------------
model User {
  id            String         @id @default(uuid())
  name          String?
  email         String         @unique
  passwordHash  String?
  companyName   String?
  phone         String?
  role          UserRole       @default(CLIENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  availableSlots Int            @default(0)
  
  // Relations
  subscriptions Subscription[]
  leads         Lead[]
  configs       ProductConfig[]
  memories      AgentMemory[]
  currencyPreferred String @default("USD")
  }

enum UserRole {
  ADMIN
  CLIENT
}

// -------------------------------------------------------------
// SUBSCRIPTIONS & PRODUCTS (Purchased via Equity Bank / Jenga API)
// -------------------------------------------------------------
model Subscription {
  id                    String      @id @default(uuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  productType           ProductType
  status                SubStatus   @default(INACTIVE)
  
  // New Pricing Model (One-Time + 20% Monthly Maintenance)
  businessSizeTier      BusinessTier @default(MICRO)
  oneTimeFee            Float?       // KES 1500 - 5000
  monthlyMaintenanceRate Float?      @default(0.20) // 20% of oneTimeFee
  lastMaintenanceBillDate DateTime?
  
  // Equity Bank / Jenga API tracking
  paymentReference      String?     @unique  // Client's unique reference for matching
  equityTransactionId   String?     @unique  // Jenga transactionId once matched
  paidPhone             String?              // Phone number that made the payment
  amountPaid            Float?
  amountExpected        Float?               // Expected payment amount (One-time or Maintenance)
  
  startDate             DateTime    @default(now())
  expiresAt             DateTime?
  
  // Relations
  config                ProductConfig?
}

enum BusinessTier {
  MICRO    // 1-5 employees (KES 1500)
  SMALL    // 6-20 employees (KES 3000)
  MEDIUM   // 21-50 employees (KES 5000)
}

enum ProductType {
  BAZZ_CONNECT
  BAZZ_FLOW
  BAZZ_DOC
  BAZZ_LEAD
}

enum SubStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
  SUSPENDED
}

// -------------------------------------------------------------
// DYNAMIC AI CONFIGURE (Central n8n pulls from here)
// -------------------------------------------------------------
model ProductConfig {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  subscriptionId  String       @unique
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  // Multi-Tenant Webhook Routing Identifier
  webhookId       String       @unique @default(uuid())
  
  // AI Agent Dynamic "Brain"
  systemPrompt    String?      @db.Text
  knowledgeBase   String?      @db.Text
  
  // Shared Configuration Options
  productType         String?  
  isConfigured        Boolean  @default(false)
  leadNotifyEmail     String?
  
  // Custom WhatsApp Integration (Bazz-Connect / Evolution API / Meta)
  whatsappPhoneId     String?
  whatsappUrl         String?
  whatsappToken       String?
  
  // Bazz-Flow (M-Pesa ERP)
  darajaConsumerKey    String?
  darajaConsumerSecret String?
  darajaShortcode      String?
  darajaPasskey        String?
  darajaCallbackUrl    String?
  erpWebhookUrl        String?
  
  // Bazz-Doc (AI Receipts / OpenAI Vision)
  openaiApiKey         String?
  docOutputWebhook     String?
  
  // Bazz-Lead (Social Media CRM)
  metaPageAccessToken  String?
  metaPageId           String?
  crmWebhookUrl        String?
  
  // Fine-tuning & Robustness
  tokenQuotaInt          Int                 @default(50000)
  tokensUsed             Int                 @default(0)
  fineTunedModelId       String?

  updatedAt       DateTime     @updatedAt
}

// -------------------------------------------------------------
// AUTONOMOUS SALES CRM (Tracked by Master n8n workflow)
// -------------------------------------------------------------
model Lead {
  id              String       @id @default(uuid())
  userId          String       // The Client this lead belongs to
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String?
  phone           String?
  email           String?
  source          String?      // e.g., 'Website Form', 'WhatsApp', 'Facebook'
  
  stage           LeadStage    @default(LEAD)
  
  // Conversation payload dumps
  lastMessage     String?      @db.Text
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum LeadStage {
  LEAD          // Newly fetched or submitted
  CONTACTED     // Agent sent standard outreach
  PROSPECTIVE   // Agent confirmed interest / qualified
  SALE          // Transaction completed
}

// -------------------------------------------------------------
// SYSTEM METRICS
// -------------------------------------------------------------
model Analytics {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  metric    String
  value     Float
}

// -------------------------------------------------------------
// JENGA API TRANSACTION DEDUPLICATION
// -------------------------------------------------------------
model ProcessedTransaction {
  id            String   @id @default(uuid())
  transactionId String   @unique   // Jenga bank statement transactionId
  amount        Float
  reference     String?
  narration     String?  @db.Text
  processedAt   DateTime @default(now())
}

// -------------------------------------------------------------
// AUDIT LOG (Tracks all payment-related system events)
// -------------------------------------------------------------
model AuditLog {
  id               String    @id @default(uuid())
  event            String    // e.g. "JENGA_POLL", "PAYMENT_MATCHED", "PENDING_APPROVAL"
  detail           String?   @db.Text
  // Multi-tenant scoping for CLI monitor streaming
  userId           String?
  // HITL (Human-in-the-Loop) gate fields
  toolName         String?   // The tool that triggered this event
  toolInput        String?   @db.Text // JSON-serialised input (for re-dispatch on approval)
  pendingApproval  Boolean   @default(false)
  approvedAt       DateTime? // Stamped when admin approves via portal or webhook
  createdAt        DateTime  @default(now())
}

// -------------------------------------------------------------
// AGENT MEMORY (Vector Store for Long-Term Context)
// -------------------------------------------------------------
model AgentMemory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  content   String   @db.Text
  embedding Unsupported("vector(1536)")
  
  metadata  Json?
  
  createdAt DateTime @default(now())

  @@index([userId])
}

// -------------------------------------------------------------
// CURRENCY & PRICING (Work Stream 1)
// -------------------------------------------------------------
model ExchangeRate {
  id Int @id @default(autoincrement())
  fromCurrency String
  toCurrency String
  rate Decimal @db.Decimal(10, 4)
  effectiveDate DateTime
  createdAt DateTime @default(now())
  
  @@unique([fromCurrency, toCurrency, effectiveDate])
}

model PricingFigure {
  id Int @id @default(autoincrement())
  featureId String @unique
  usdAmount Decimal @db.Decimal(10, 2)
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -------------------------------------------------------------
// INSURANCE & HITL GOVERNANCE (Work Stream 2)
// -------------------------------------------------------------
model InsurancePolicy {
  id Int @id @default(autoincrement())
  policyName String
  provider String
  policyNumber String @unique
  coverageAmount Decimal @db.Decimal(12, 2)
  coverageType String?
  effectiveDate DateTime
  expiryDate DateTime
  certificateUrl String?
  verified Boolean @default(false)
  verifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HITLGuarantee {
  id Int @id @default(autoincrement())
  agentLevel Int
  guaranteeText String
  humanApprovalRequired Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplianceAuditLog {
  id Int @id @default(autoincrement())
  eventType String
  agentLevel Int?
  decisionId String?
  humanApproval Boolean?
  timestamp DateTime @default(now())
}
